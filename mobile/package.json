{
  "name": "lol-companion-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-expo.ps1",
    "web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-web.ps1",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-android-native.ps1",
    "android:expo-go": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/expo-android.ps1",
    "android:fix": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/fix-android-emulator.ps1",
    "ios": "expo start --ios",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.7.7",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/utils/**/*.ts",
      "src/constants/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 40,
        "statements": 40
      }
    }
  }
}
